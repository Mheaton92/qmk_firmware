	    KC_TAB,  KC_QUOT, KC_COMM, KC_DOT,  KC_P, KC_Y, KC_F, KC_G, KC_C, KC_R, KC_L, KC_SLSH, KC_BSLS, KC_DEL,
	    KC_ESC,  KC_A,    KC_O,    KC_E,    KC_U, KC_I, KC_D, KC_H, KC_T, KC_N, KC_S, KC_MINS, KC_ENT, KC_LSFT,
            CT_CLN, KC_Q,    KC_J,    KC_K,    KC_X, KC_B, KC_M, KC_W, KC_V, KC_Z, KC_PGUP, KC_UP, KC_PGDN,
	    KC_LCTL, KC_LALT, TT(1),   KC_BSPC, KC_LGUI, KC_SPC, TT(2), KC_RGUI, KC_LEFT, KC_DOWN, KC_RGHT),


	[LW] = LAYOUT_directional(
